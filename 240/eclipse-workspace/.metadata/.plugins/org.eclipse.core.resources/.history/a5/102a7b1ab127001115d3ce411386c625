package cmu.edu;

import javafx.stage.Stage;
import javafx.application.Application;
import javafx.geometry.Insets;
import javafx.geometry.Pos;
import javafx.scene.Scene;
import javafx.scene.control.Button;
import javafx.scene.control.Label;
import javafx.scene.control.TextField;
import javafx.scene.layout.StackPane;
import javafx.scene.layout.FlowPane;
import javafx.scene.paint.Color;
import javafx.scene.shape.Circle;
import javafx.scene.text.Font;

public class Driver extends Application{
	public static void main(String [] args)
	{
	launch(args);	
		
	}
	public void start(Stage pStage)
	{
		
		
		
		FlowPane userPane = new FlowPane();
		userPane.getChildren().addAll(new Label("User Name: "), new TextField());
		userPane.setTranslateY(100);
		userPane.setPadding(new Insets(20));
		
		FlowPane passPane = new FlowPane();
		userPane.getChildren().addAll(new Label("Password: "), new TextField());
		userPane.setPadding(new Insets(20));
		
		FlowPane buttonPane = new FlowPane();
		userPane.getChildren().addAll(new Button("Login"), new Button("close"));
		
		Label lbl = new Label("CMU");
		lbl.setTextFill(Color.GOLD);
		lbl.setFont(new Font("Menlo",30));
		lbl.setAlignment(Pos.CENTER);

		//lbl.setTranslateY(25);
		
		Circle circle = new Circle(50);
		circle.setFill(Color.MAROON);
		circle.setAlignment(Pos.CENTER);

		
		FlowPane pane = new FlowPane();
		pane.setAlignment(Pos.CENTER);
		pane.getChildren().addAll(circle,lbl,userPane, passPane, buttonPane);
		pane.setStyle("-fx-background-color: orange");
		
		
		
				
		Scene scene = new Scene(pane, 300,300);
		
		pStage.setTitle("My GUI");
		pStage.setScene(scene);
		pStage.show();
	}
	
}
