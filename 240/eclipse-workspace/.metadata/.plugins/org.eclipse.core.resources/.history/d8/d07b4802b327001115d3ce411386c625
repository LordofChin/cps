package cmu.edu;

import javafx.stage.Stage;
import javafx.application.Application;
import javafx.geometry.Insets;
import javafx.geometry.Pos;
import javafx.scene.Scene;
import javafx.scene.control.Button;
import javafx.scene.control.Label;
import javafx.scene.control.TextField;
import javafx.scene.layout.StackPane;
import javafx.scene.layout.FlowPane;
import javafx.scene.layout.GridPane;
import javafx.scene.paint.Color;
import javafx.scene.shape.Circle;
import javafx.scene.text.Font;

public class Driver extends Application{
	public static void main(String [] args)
	{
	launch(args);	
		
	}
	public void start(Stage pStage)
	{
		
		
		
		FlowPane userPane = new FlowPane();
		userPane.getChildren().addAll(new Label("User Name: "), new TextField());
		userPane.setAlignment(Pos.CENTER);
		userPane.setHgap(10);
		userPane.setPadding(new Insets(0,0,0,60));

		FlowPane passPane = new FlowPane();
		passPane.getChildren().addAll(new Label("Password: "), new TextField());
		passPane.setAlignment(Pos.CENTER);
		passPane.setHgap(10);
		passPane.setPadding(new Insets(0,0,0,60));
		
		FlowPane buttonPane = new FlowPane();
		buttonPane.getChildren().addAll(new Button("Login"), new Button("close"));
		buttonPane.setAlignment(Pos.CENTER);
		buttonPane.setHgap(10);
		buttonPane.setPadding(new Insets(0,0,0,60));
		
		Label lbl = new Label("CMU");
		lbl.setTextFill(Color.GOLD);
		lbl.setFont(new Font("Menlo",30));
		lbl.setAlignment(Pos.CENTER);

		//lbl.setTranslateY(25);
		
		Circle circle = new Circle(50);
		circle.setFill(Color.MAROON);

		GridPane gPane = new GridPane();
		gPane.add(new Label("Username: "), 0, 0);
		gPane.add(new TextField(), 1, 0);
		gPane.add(new Label("Password: "), 0, 1);
		gPane.add(new TextField(), 1, 1);
		
		FlowPane pane = new FlowPane();
		pane.setAlignment(Pos.CENTER);
		pane.getChildren().addAll(circle,lbl,userPane, passPane, buttonPane, gPane);
		pane.setStyle("-fx-background-color: orange; -fx-border-color: green; -fx-border-width: 10;");
		pane.setVgap(10);
		
		
		
				
		Scene scene = new Scene(pane, 300,300);
		
		pStage.setTitle("My GUI");
		pStage.setScene(scene);
		pStage.show();
	}
	
}
